<div id="success-modal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeSuccessModal()">
  <div class="modal-box">
    <div class="modal-icon">
      <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
    </div>
    <h3>Appointment Requested!</h3>
    <p>Thank you, <strong id="modal-patient-name"></strong>. Your appointment request has been received. Our team will call you within the hour to confirm your booking details.</p>
    <button class="modal-close-btn" onclick="closeSuccessModal()">Done</button>
  </div>
</div>

<script>
function scrollTo(hash) {
  document.querySelector(hash)?.scrollIntoView({ behavior: 'smooth' });
}

function submitAppt() {
  const fname = document.getElementById('appt-fname').value.trim();
  const lname = document.getElementById('appt-lname').value.trim();
  const phone = document.getElementById('appt-phone').value.trim();

  if (!fname || !lname) {
    alert('Please enter your first and last name.');
    return;
  }
  if (!phone) {
    alert('Please enter a phone number so we can confirm your booking.');
    return;
  }

  document.getElementById('modal-patient-name').textContent = fname + ' ' + lname;
  document.getElementById('success-modal').style.display = 'flex';

  // Clear form
  ['appt-fname','appt-lname','appt-phone','appt-email','appt-reason'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('appt-dept').value = '';
  document.getElementById('appt-date').value = '';
}

function closeSuccessModal() {
  document.getElementById('success-modal').style.display = 'none';
}

// Set min date for appointment picker to today
(function() {
  const today = new Date().toISOString().split('T')[0];
  const f = document.getElementById('appt-date');
  if (f) f.min = today;
})();
</script>
