<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MedLink Hospital — Care You Can Count On</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --navy:     #0B1F3A;
  --navy-md:  #162F54;
  --navy-lt:  #1E4080;
  --blue:     #2B7FE0;
  --blue-lt:  #EBF4FF;
  --mint:     #10B98D;
  --mint-lt:  #E6F9F4;
  --cloud:    #F4F8FF;
  --white:    #FFFFFF;
  --text:     #1A2B45;
  --text-md:  #4A5E78;
  --text-lt:  #8EA3BC;
  --border:   #DDE6F0;
  --red:      #E84855;
  --amber:    #F59E0B;
  --radius:   10px;
  --shadow:   0 2px 8px rgba(11,31,58,.08);
  --shadow-md:0 8px 24px rgba(11,31,58,.12);
}

html { scroll-behavior: smooth; }
body { font-family: -apple-system, "Segoe UI", Roboto, Arial, sans-serif; color: var(--text); background: var(--white); font-size: 15px; line-height: 1.6; }

/* ── UTILS ── */
.container { max-width: 1120px; margin: 0 auto; padding: 0 28px; }
.section    { padding: 80px 0; }
.section-alt{ background: var(--cloud); }
.eyebrow    { font-size: 11px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; color: var(--mint); margin-bottom: 10px; }
.section-title { font-size: 32px; font-weight: 800; color: var(--navy); line-height: 1.2; margin-bottom: 14px; }
.section-sub   { font-size: 16px; color: var(--text-md); max-width: 520px; line-height: 1.7; }
.center { text-align: center; }
.center .section-sub { margin: 0 auto; }

/* ── NAV ── */
.nav {
  position: sticky; top: 0; z-index: 200;
  background: rgba(11,31,58,.97); backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(255,255,255,.07);
}
.nav-inner {
  display: flex; align-items: center; justify-content: space-between;
  height: 66px; gap: 24px;
}
.nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.nav-brand .logo {
  width: 36px; height: 36px; background: var(--mint); border-radius: 9px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.nav-brand .logo svg { width: 20px; height: 20px; fill: white; }
.nav-brand-text { font-size: 18px; font-weight: 800; color: white; letter-spacing: -.3px; }
.nav-brand-text span { color: var(--mint); }

.nav-links { display: flex; align-items: center; gap: 4px; }
.nav-links a {
  padding: 7px 13px; color: rgba(255,255,255,.7); font-size: 14px; font-weight: 500;
  text-decoration: none; border-radius: 6px; transition: all .15s;
}
.nav-links a:hover { color: white; background: rgba(255,255,255,.08); }

.nav-right { display: flex; align-items: center; gap: 10px; }
.nav-emergency {
  display: flex; align-items: center; gap: 6px; padding: 7px 14px;
  background: var(--red); border-radius: 7px; color: white; font-size: 13px; font-weight: 700;
  text-decoration: none; transition: background .15s;
}
.nav-emergency:hover { background: #C8333F; }
.nav-emergency svg { width: 14px; height: 14px; fill: white; }
.nav-appt {
  padding: 8px 16px; background: var(--mint); border: none; border-radius: 7px;
  color: white; font-size: 13px; font-weight: 700; cursor: pointer; transition: background .15s;
}
.nav-appt:hover { background: #0DA07A; }

/* ── HERO ── */
.hero {
  background: var(--navy);
  min-height: calc(100vh - 66px);
  display: grid; grid-template-columns: 1fr 1fr; align-items: center;
  overflow: hidden; position: relative;
}
.hero-left { padding: 80px 60px 80px 0; }
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px;
  background: rgba(16,185,141,.15); border: 1px solid rgba(16,185,141,.3);
  border-radius: 999px; margin-bottom: 28px;
}
.hero-badge-dot { width: 7px; height: 7px; background: var(--mint); border-radius: 50%; animation: glow 2.5s ease-in-out infinite; }
@keyframes glow { 0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(16,185,141,.4)} 50%{opacity:.7;box-shadow:0 0 0 5px rgba(16,185,141,0)} }
.hero-badge-text { font-size: 12px; font-weight: 600; color: var(--mint); letter-spacing: .4px; }

.hero h1 {
  font-family: Georgia, "Times New Roman", serif;
  font-size: clamp(36px, 4vw, 54px); font-weight: 700; color: white; line-height: 1.12;
  margin-bottom: 20px; letter-spacing: -.5px;
}
.hero h1 em { color: var(--mint); font-style: normal; }

.hero-sub { font-size: 17px; color: rgba(255,255,255,.65); line-height: 1.7; margin-bottom: 36px; max-width: 440px; }

.hero-ctas { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.btn-hero-primary {
  padding: 14px 28px; background: var(--mint); border: none; border-radius: var(--radius);
  color: white; font-size: 15px; font-weight: 700; cursor: pointer; transition: all .15s;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-hero-primary:hover { background: #0DA07A; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(16,185,141,.3); }
.btn-hero-primary svg { width: 16px; height: 16px; fill: white; }
.btn-hero-secondary {
  padding: 13px 24px; background: transparent; border: 1.5px solid rgba(255,255,255,.25);
  border-radius: var(--radius); color: rgba(255,255,255,.85); font-size: 15px; font-weight: 600;
  cursor: pointer; transition: all .15s; text-decoration: none; display: inline-block;
}
.btn-hero-secondary:hover { border-color: rgba(255,255,255,.55); color: white; }

.hero-stats { display: flex; gap: 32px; margin-top: 48px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.1); }
.hero-stat-val { font-size: 28px; font-weight: 800; color: white; line-height: 1; }
.hero-stat-val span { color: var(--mint); }
.hero-stat-lbl { font-size: 12px; color: rgba(255,255,255,.5); margin-top: 4px; font-weight: 500; }

/* hero right — illustrated cross panel */
.hero-right {
  position: relative; height: 100%; min-height: calc(100vh - 66px);
  background: var(--navy-md);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.hero-right::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at center, rgba(16,185,141,.12) 0%, transparent 70%);
}
.cross-wrap { position: relative; z-index: 1; }
.cross-svg { width: 280px; height: 280px; opacity: .9; }
.hero-pills {
  position: absolute; display: flex; flex-direction: column; gap: 12px;
}
.hero-pills.left  { left: -140px; top: 50%; transform: translateY(-50%); }
.hero-pills.right { right: -140px; top: 50%; transform: translateY(-50%); }
.hero-pill {
  background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
  border-radius: 999px; padding: 8px 16px; white-space: nowrap;
  font-size: 12px; font-weight: 600; color: rgba(255,255,255,.75);
  display: flex; align-items: center; gap: 8px;
}
.hero-pill .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

/* ── TRUST STRIP ── */
.trust-strip { background: var(--mint); padding: 0; }
.trust-inner {
  display: flex; align-items: stretch; justify-content: space-between;
}
.trust-item {
  flex: 1; padding: 22px 28px; display: flex; align-items: center; gap: 14px;
  border-right: 1px solid rgba(255,255,255,.2);
}
.trust-item:last-child { border-right: none; }
.trust-item svg { width: 26px; height: 26px; fill: white; flex-shrink: 0; opacity: .9; }
.trust-item-text strong { display: block; font-size: 14px; font-weight: 700; color: white; }
.trust-item-text span   { font-size: 12px; color: rgba(255,255,255,.75); }

/* ── SERVICES ── */
.services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
.service-card {
  background: white; border: 1.5px solid var(--border); border-radius: 12px;
  padding: 28px 24px; cursor: pointer; transition: all .2s; text-decoration: none; display: block;
}
.service-card:hover { border-color: var(--blue); box-shadow: var(--shadow-md); transform: translateY(-3px); }
.service-icon {
  width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center;
  justify-content: center; margin-bottom: 18px; flex-shrink: 0;
}
.service-icon svg { width: 26px; height: 26px; }
.service-card h3 { font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
.service-card p  { font-size: 13px; color: var(--text-md); line-height: 1.6; }
.service-link    { font-size: 13px; font-weight: 700; color: var(--blue); margin-top: 14px; display: flex; align-items: center; gap: 5px; }
.service-link svg { width: 13px; height: 13px; fill: var(--blue); transition: transform .15s; }
.service-card:hover .service-link svg { transform: translateX(3px); }

/* ── HOW IT WORKS ── */
.steps-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin-top: 56px; position: relative; }
.steps-row::before {
  content: ''; position: absolute; top: 26px; left: calc(12.5% + 26px); right: calc(12.5% + 26px);
  height: 2px; background: linear-gradient(to right, var(--mint), var(--blue)); z-index: 0;
}
.step { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 0 16px; position: relative; z-index: 1; }
.step-num {
  width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 800; color: white; margin-bottom: 18px; flex-shrink: 0;
  box-shadow: 0 0 0 4px var(--cloud);
}
.step h4 { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
.step p  { font-size: 13px; color: var(--text-md); line-height: 1.6; }

/* ── DEPARTMENTS ── */
.depts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 48px; }
.dept-card {
  padding: 22px 18px; border-radius: 10px; border: 1.5px solid var(--border);
  cursor: pointer; transition: all .18s; text-decoration: none; display: block;
}
.dept-card:hover { border-color: var(--mint); background: var(--mint-lt); }
.dept-card svg { width: 28px; height: 28px; margin-bottom: 12px; }
.dept-card h4 { font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
.dept-card p  { font-size: 12px; color: var(--text-md); }
.dept-tag     { display: inline-block; margin-top: 10px; font-size: 10px; font-weight: 700; letter-spacing: .5px; padding: 2px 8px; border-radius: 999px; }

/* ── TESTIMONIALS ── */
.testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
.testimonial-card {
  background: white; border: 1.5px solid var(--border); border-radius: 12px; padding: 28px 24px;
  box-shadow: var(--shadow);
}
.stars { color: var(--amber); font-size: 15px; margin-bottom: 14px; letter-spacing: 2px; }
.testimonial-card blockquote { font-size: 14px; color: var(--text-md); line-height: 1.7; margin-bottom: 20px; font-style: italic; }
.testimonial-author { display: flex; align-items: center; gap: 12px; }
.author-avatar {
  width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: 14px; font-weight: 800; color: white; flex-shrink: 0;
}
.author-name { font-size: 14px; font-weight: 700; color: var(--navy); }
.author-tag  { font-size: 11px; color: var(--text-lt); }

/* ── APPOINTMENT ── */
.appt-wrap {
  background: var(--navy); border-radius: 20px; padding: 60px; display: grid;
  grid-template-columns: 1fr 1fr; gap: 60px; align-items: start;
}
.appt-left h2 { font-family: Georgia, serif; font-size: 32px; color: white; line-height: 1.2; margin-bottom: 14px; }
.appt-left p  { color: rgba(255,255,255,.6); font-size: 15px; line-height: 1.7; margin-bottom: 28px; }
.appt-contact { display: flex; flex-direction: column; gap: 12px; }
.appt-contact-item { display: flex; align-items: center; gap: 12px; }
.appt-contact-item svg { width: 18px; height: 18px; fill: var(--mint); flex-shrink: 0; }
.appt-contact-item span { font-size: 14px; color: rgba(255,255,255,.75); }
.appt-contact-item strong { color: white; }

.appt-form { display: flex; flex-direction: column; gap: 14px; }
.appt-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.appt-field { display: flex; flex-direction: column; gap: 6px; }
.appt-field label { font-size: 11px; font-weight: 700; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: .5px; }
.appt-field input, .appt-field select, .appt-field textarea {
  padding: 11px 13px; background: rgba(255,255,255,.08); border: 1.5px solid rgba(255,255,255,.15);
  border-radius: 8px; font-size: 14px; color: white; outline: none; transition: border-color .15s;
  font-family: inherit;
}
.appt-field input::placeholder, .appt-field textarea::placeholder { color: rgba(255,255,255,.3); }
.appt-field input:focus, .appt-field select:focus, .appt-field textarea:focus {
  border-color: var(--mint); background: rgba(255,255,255,.12);
}
.appt-field select option { background: var(--navy); color: white; }
.appt-field textarea { min-height: 80px; resize: vertical; }
.btn-book {
  padding: 13px 28px; background: var(--mint); border: none; border-radius: var(--radius);
  color: white; font-size: 15px; font-weight: 700; cursor: pointer; transition: all .15s;
  display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 4px;
}
.btn-book:hover { background: #0DA07A; }
.btn-book svg { width: 16px; height: 16px; fill: white; }

/* ── EMERGENCY BANNER ── */
.emergency-banner {
  background: linear-gradient(135deg, var(--red) 0%, #C8333F 100%);
  padding: 40px 0;
}
.emergency-inner {
  display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
}
.emergency-left { display: flex; align-items: center; gap: 20px; }
.emergency-icon {
  width: 56px; height: 56px; background: rgba(255,255,255,.2); border-radius: 50%;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.emergency-icon svg { width: 28px; height: 28px; fill: white; }
.emergency-title { font-size: 22px; font-weight: 800; color: white; margin-bottom: 4px; }
.emergency-sub   { font-size: 14px; color: rgba(255,255,255,.8); }
.emergency-num {
  font-size: 36px; font-weight: 900; color: white; letter-spacing: -1px;
  text-decoration: none; display: block;
}
.emergency-num small { font-size: 13px; font-weight: 500; color: rgba(255,255,255,.7); display: block; letter-spacing: 0; }

/* ── FOOTER ── */
footer { background: var(--navy); padding: 64px 0 0; }
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,.08); }
.footer-brand p { font-size: 13px; color: rgba(255,255,255,.45); line-height: 1.8; margin-top: 14px; max-width: 260px; }
.footer-col h5 { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,.4); margin-bottom: 14px; }
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
.footer-col ul a { font-size: 13px; color: rgba(255,255,255,.6); text-decoration: none; transition: color .15s; }
.footer-col ul a:hover { color: var(--mint); }
.footer-bottom { padding: 20px 0; display: flex; align-items: center; justify-content: space-between; }
.footer-bottom p { font-size: 12px; color: rgba(255,255,255,.3); }
.footer-accred { display: flex; align-items: center; gap: 16px; }
.accred-tag {
  font-size: 10px; font-weight: 700; color: rgba(255,255,255,.4); padding: 4px 10px;
  border: 1px solid rgba(255,255,255,.12); border-radius: 4px; letter-spacing: .4px;
}

/* ── MODAL ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(11,31,58,.6); z-index: 500;
  display: flex; align-items: center; justify-content: center; padding: 20px;
  backdrop-filter: blur(4px);
}
.modal-box {
  background: white; border-radius: 16px; padding: 36px; max-width: 420px; width: 100%;
  box-shadow: 0 30px 80px rgba(0,0,0,.3); text-align: center;
}
.modal-box .modal-icon {
  width: 64px; height: 64px; background: var(--mint-lt); border-radius: 50%;
  display: flex; align-items: center; justify-content: center; margin: 0 auto 18px;
}
.modal-box .modal-icon svg { width: 32px; height: 32px; fill: var(--mint); }
.modal-box h3 { font-size: 20px; font-weight: 800; color: var(--navy); margin-bottom: 10px; }
.modal-box p  { font-size: 14px; color: var(--text-md); line-height: 1.7; margin-bottom: 24px; }
.modal-close-btn {
  padding: 11px 28px; background: var(--mint); border: none; border-radius: 8px;
  color: white; font-size: 14px; font-weight: 700; cursor: pointer; transition: background .15s;
}
.modal-close-btn:hover { background: #0DA07A; }

/* ── RESPONSIVE ── */
@media (max-width: 960px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-right { display: none; }
  .hero-left { padding: 60px 0; }
  .services-grid, .depts-grid { grid-template-columns: 1fr 1fr; }
  .steps-row { grid-template-columns: 1fr 1fr; gap: 32px; }
  .steps-row::before { display: none; }
  .testimonials-grid { grid-template-columns: 1fr; }
  .appt-wrap { grid-template-columns: 1fr; padding: 36px 28px; gap: 36px; }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  .trust-inner { flex-wrap: wrap; }
  .trust-item { flex: 1 0 50%; }
}
@media (max-width: 640px) {
  .services-grid, .depts-grid, .steps-row { grid-template-columns: 1fr; }
  .appt-row { grid-template-columns: 1fr; }
  .nav-links { display: none; }
  .hero-stats { flex-wrap: wrap; gap: 20px; }
  .section { padding: 56px 0; }
  .footer-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- ══════════ NAV ══════════ -->
<nav class="nav">
  <div class="container">
    <div class="nav-inner">
      <a href="#" class="nav-brand">
        <div class="logo">
          <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
        </div>
        <span class="nav-brand-text">Med<span>Link</span></span>
      </a>
      <div class="nav-links">
        <a href="#services">Services</a>
        <a href="#departments">Departments</a>
        <a href="#how-it-works">How It Works</a>
        <a href="#appointment">Appointments</a>
        <a href="#contact">Contact</a>
      </div>
      <div class="nav-right">
        <a href="#emergency" class="nav-emergency">
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
          Emergency
        </a>
        <button class="nav-appt" onclick="scrollTo('#appointment')">Book Appointment</button>
      </div>
    </div>
  </div>
</nav>

<!-- ══════════ HERO ══════════ -->
<section class="hero" id="home">
  <div class="container" style="display:contents">
    <div class="hero-left" style="padding-left:max(28px, calc((100vw - 1120px)/2 + 28px))">
      <div class="hero-badge">
        <div class="hero-badge-dot"></div>
        <span class="hero-badge-text">Accepting new patients · Open 24 / 7</span>
      </div>
      <h1>Care you can<br><em>count on,</em><br>whenever you need it.</h1>
      <p class="hero-sub">MedLink Hospital brings world-class specialists, modern diagnostics, and compassionate nursing together under one roof — for you and your family.</p>
      <div class="hero-ctas">
        <button class="btn-hero-primary" onclick="scrollTo('#appointment')">
          <svg viewBox="0 0 24 24"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
          Book Appointment
        </button>
        <a href="#services" class="btn-hero-secondary">Explore Services</a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="hero-stat-val">25<span>k+</span></div>
          <div class="hero-stat-lbl">Patients served</div>
        </div>
        <div>
          <div class="hero-stat-val">120<span>+</span></div>
          <div class="hero-stat-lbl">Specialist doctors</div>
        </div>
        <div>
          <div class="hero-stat-val">18<span></span></div>
          <div class="hero-stat-lbl">Departments</div>
        </div>
        <div>
          <div class="hero-stat-val">24<span>/7</span></div>
          <div class="hero-stat-lbl">Emergency care</div>
        </div>
      </div>
    </div>

    <!-- Right panel -->
    <div class="hero-right">
      <div class="cross-wrap">
        <!-- Glowing medical cross SVG -->
        <svg class="cross-svg" viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
